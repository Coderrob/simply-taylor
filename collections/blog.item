
{.section item}

  <!--WRAPPER-->
  <article id="post-{id}" class="{@|item-classes}" data-item-id="{id}">

    <!--POST TILE-->
    <h1 class="title" data-content-field="title">
      {.passthrough?}
        <a href="{sourceUrl}" target="_blank">{title}</a>
      {.or}
        {title}
      {.end}
    </h1>

    <!--AUTHOR AND DATE-->
    {@|apply blog-item-meta.block}

    <!--MAIN CONTENT-->
    <div class="post-body">
      {body}
    </div>

    <!--BLOG INJECTION-->
    {postItemInjectCode}

    <!--CATEGORIES-->
    {.section categories}
      <div class="post-taxonomy">
        {.repeated section categories}
          <a class="category" href="{collection.fullUrl}?category={@|url-encode}">{@}</a>
        {.end}
      </div>
    {.end}

    <!--TAGS-->
    {.section tags}
      <div class="post-taxonomy">
        {.repeated section tags}
          <a class="tag" href="{collection.fullUrl}?tag={@|url-encode}">{@}</a>
        {.end}
      </div>
    {.end}

    <!--SHARE AND LIKE-->
    <div class="post-actions">
      {@|like-button}
      {@|social-button}
    </div>


    <!--LOCATION-->
    {.section location}
      {.section addressTitle}
        {addressTitle}
        {addressLine1}
        {addressLine2}
        {addressCountry}
      {.end}
    {.end}

    <!--COMMENTS-->
    {@|comments}

  </article>

{.end}


<!--PAGINATION-->
{.section pagination}
  <nav class="blog-item-pagination">

    <!--NEWER PAGE-->
    {.section prevItem}
      <a href="{fullUrl}">Newer</a>
    {.or}
      <a class="disabled">Newer</a>
    {.end}

    <!--OLDER PAGE-->
    {.section nextItem}
      <a href="{fullUrl}">Older</a>
    {.or}
      <a class="disabled">Older</a>
    {.end}

  </nav>
{.end}
